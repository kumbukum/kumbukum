extends layout

block settings
	h4.mb-4 Usage

	.card.mb-4
		.card-body
			h5.card-title
				i.bi.bi-bar-chart.me-2
				| Storage Usage
			#usage-stats
				p.text-muted Loading usage data...

block scripts
	script.
		document.addEventListener('DOMContentLoaded', async function() {
			try {
				var data = await api('GET', '/counts');
				var totals = { notes: 0, memories: 0, urls: 0, projects: 0 };
				for (var pid in data) {
					totals.projects++;
					totals.notes += data[pid].notes || 0;
					totals.memories += data[pid].memory || 0;
					totals.urls += data[pid].urls || 0;
				}
				var el = document.getElementById('usage-stats');
				el.innerHTML = '<table class="table"><tbody>'
					+ '<tr><td><i class="bi bi-file-text me-2"></i>Notes</td><td>' + totals.notes + '</td></tr>'
					+ '<tr><td><i class="bi bi-lightbulb me-2"></i>Memories</td><td>' + totals.memories + '</td></tr>'
					+ '<tr><td><i class="bi bi-link-45deg me-2"></i>URLs</td><td>' + totals.urls + '</td></tr>'
					+ '<tr><td><i class="bi bi-folder me-2"></i>Projects</td><td>' + totals.projects + '</td></tr>'
					+ '</tbody></table>';
			} catch (err) {
				document.getElementById('usage-stats').innerHTML = '<p class="text-danger">Failed to load usage data</p>';
			}
		});
