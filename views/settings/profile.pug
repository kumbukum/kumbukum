extends layout

block settings
	h4.mb-4 Profile Settings

	form#profile-form
		.mb-3
			label.form-label Name
			input.form-control#profile-name(type="text" value=user.name)
		.mb-3
			label.form-label Email
			input.form-control#profile-email(type="email" value=user.email)
		.mb-3
			label.form-label Timezone
			input.form-control#profile-timezone(type="text" value=user.timezone)
		button.btn.btn-primary(type="submit") Save Changes

	hr

	h5 Reset Password
	p.text-muted A new random password will be generated. Copy it before closing.
	button.btn.btn-warning#reset-password-btn Reset Password
	#password-result.d-none.mt-3
		.alert.alert-success
			p Your new password:
			.input-group
				input.form-control#new-password-value(type="text" readonly)
				button.btn.btn-outline-secondary#copy-password-btn
					i.bi.bi-clipboard
					|  Copy
			button.btn.btn-primary.mt-2#password-copied-btn I copied the password

	hr

	h5 Typesense Reindex
	p.text-muted Rebuild all search indexes from the database.
	button.btn.btn-outline-danger#reindex-btn Reindex All Data
	#reindex-result.d-none.mt-2

block scripts
	script(src="/static/js/settings.js")
