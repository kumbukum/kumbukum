doctype html
html(lang="en")
	head
		meta(charset="UTF-8")
		meta(name="viewport" content="width=device-width, initial-scale=1")
		title #{title || 'Kumbukum'}
		link(href='/static/images/favicon.ico' rel="shortcut icon")
		link(href="/static/css/vendor.css" rel="stylesheet")
		link(href="/static/css/app.css" rel="stylesheet")
		block head
	body
		block body
			if impersonating
				.alert.alert-warning.text-center.mb-0.rounded-0.py-1(style="position:sticky;top:0;z-index:1060")
					i.bi.bi-shield-exclamation.me-2
					strong Sysadmin
					|  — viewing as #{impersonatingName}
					button.btn.btn-sm.btn-outline-dark.ms-3#exit-impersonation Exit

			nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.sticky-top
				.container-fluid
					a.navbar-brand(href="/dashboard")
						include includes/logo_white
					.d-flex.align-items-center
						if user
							.dropdown
								button.btn.btn-outline-light.btn-sm.dropdown-toggle(type="button" data-bs-toggle="dropdown")
									i.bi.bi-person-circle.me-1
									= user.name
								ul.dropdown-menu.dropdown-menu-end
									li: a.dropdown-item(href="/settings/profile") Profile
									li: a.dropdown-item(href="/settings/security") Security
									li: a.dropdown-item(href="/settings/tokens") Access Tokens
									li: hr.dropdown-divider
									li: a.dropdown-item(href="/settings/tokens") API Docs
									li: hr.dropdown-divider
									li: a.dropdown-item(href="#" onclick="logout()") Logout

			.container-fluid
				.row
					aside.col-md-2.bg-light.vh-100.p-3.sidebar#sidebar
						block sidebar
							.d-flex.justify-content-between.align-items-center.mb-3
								h6.mb-0 Your projects
								button.btn.btn-sm.btn-outline-primary#new-project-btn(title="New project")
									i.bi.bi-plus
							#project-list
							hr.my-3
							a.d-flex.align-items-center.text-decoration-none.text-muted.small(href="/trash")
								i.bi.bi-trash.me-2
								| Trash
								span.badge.bg-danger.ms-auto.d-none#trash-count-badge

					main.col-md-7.p-4#main-content
						block content

					aside.col-md-3.bg-light.vh-100.p-3.border-start#chat-sidebar
						block chat
							include includes/chat_sidebar

		script(src="/socket.io/socket.io.js")
		script.
			var __host_id = "#{host_id}";
		script(src="/static/js/vendor.js" type="module")
		script(src="/static/js/chat.js")
		script(src="/static/js/app.js")
		if impersonating
			script.
				document.getElementById('exit-impersonation')?.addEventListener('click', async () => {
					const res = await fetch('/api/v1/admin/exit-impersonation', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
					const data = await res.json();
					if (data.ok) window.location.href = data.redirect;
				});
		block scripts
