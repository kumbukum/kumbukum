#project-overview.d-flex.flex-column.position-relative.project-drop-zone(style="min-height:calc(100vh - 130px)")
	.project-drop-overlay.d-none
		.drop-overlay-card
			.drop-overlay-icon
				!= icon('uploadCloud')
			h5 Files upload
			p.text-muted Drop files here to import as notes
	.text-muted.text-center.mt-5
		!= icon('folderOpen', 'd-block', { style: 'font-size:2rem' })
		| Select a project from the sidebar
