.d-flex.justify-content-between.align-items-center.mb-3
	h4
		i.bi.bi-link-45deg.me-2
		| Saved URLs
	button.btn.btn-sm.btn-primary#new-url-btn
		i.bi.bi-plus-lg.me-1
		| Add URL

.d-flex.align-items-center.mb-2.gap-2#batch-toolbar(data-type="urls")
	.form-check
		input.form-check-input#select-all-cb(type="checkbox")
		label.form-check-label.small(for="select-all-cb") Select all
	.batch-actions.d-none.d-flex.align-items-center.gap-2#batch-actions
		span.badge.bg-secondary#batch-count 0 selected
		button.btn.btn-outline-danger.btn-sm#batch-delete-btn
			i.bi.bi-trash.me-1
			| Delete
		button.btn.btn-outline-primary.btn-sm#batch-move-btn
			i.bi.bi-arrow-right-circle.me-1
			| Move
		button.btn.btn-outline-secondary.btn-sm#batch-copy-btn
			i.bi.bi-copy.me-1
			| Copy
.d-none.text-center.small.py-1.px-2.bg-light.rounded.mb-2#select-all-records-banner

#urls-list.list-group
