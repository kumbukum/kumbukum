.d-flex.justify-content-between.align-items-center.mb-3
	h4 Memories
	button.btn.btn-sm.btn-primary#new-memory-btn
		i.bi.bi-plus-lg
		span.ms-1 New Memory

#batch-toolbar(data-type="memories")
	.form-check.mb-2
		input.form-check-input#select-all-cb(type="checkbox")
		label.form-check-label.small(for="select-all-cb") Select all
	#batch-actions.batch-floating-bar.d-none
		.batch-floating-inner
			.d-flex.align-items-center.gap-3
				span.batch-floating-count#batch-count 0 selected
				.d-flex.align-items-center.gap-2
					button.btn.btn-sm#batch-delete-btn
						i.bi.bi-trash.me-1
						| Delete
					button.btn.btn-sm#batch-move-btn
						i.bi.bi-arrow-right-circle.me-1
						| Move
					button.btn.btn-sm#batch-copy-btn
						i.bi.bi-copy.me-1
						| Copy
				span.batch-floating-banner.small.d-none#select-all-records-banner
			button.btn.btn-sm.batch-floating-close#batch-dismiss-btn(type="button")
				i.bi.bi-x-lg

#memories-list.list-group
