extends ../auth_layout

block head
	title Forgot Password — Kumbukum

block body
	.container
		.row.justify-content-center.mt-5
			.col-md-5
				.card.shadow
					.card-body.p-4
						.text-center.mb-4.logo-form
							include ../includes/logo_black

						h3.text-center.mb-4 Reset your password

						form#forgot-password-form
							.mb-3
								label.form-label(for="email") Email
								input.form-control#email(type="email" name="email" required autofocus)
							button.btn.btn-primary.w-100(type="submit") Send Reset Link

						.text-center.mt-3
							a(href="/login") Back to login

block scripts
	script(src="/static/js/vendor.js" type="module")
	script(src="/static/js/auth.js")
