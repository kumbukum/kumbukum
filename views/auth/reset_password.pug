extends ../auth_layout

block head
	title Password Reset — Kumbukum

block body
	.container
		.row.justify-content-center.mt-5
			.col-md-5
				.card.shadow
					.card-body.p-4
						.text-center.mb-4.logo-form
							include ../includes/logo_black

						if error
							.alert.alert-danger= error
							.text-center.mt-3
								a(href="/forgot-password") Try again

						else
							h3.text-center.mb-4 Your new password

							.alert.alert-info.text-center
								p.mb-1 Your new password is:
								h4.mb-0.font-monospace.user-select-all#new-password= password

							p.text-muted.text-center.small Copy this password and use it to sign in. You can change it later in your security settings.

							form(action="/reset-password/confirm" method="POST")
								input(type="hidden" name="token" value=token)
								button.btn.btn-primary.w-100(type="submit") Continue to Login
