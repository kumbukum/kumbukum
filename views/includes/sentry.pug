//- Sentry Browser SDK — loaded via CDN bundle, tunneled through /sentun
if sentry && sentry.clientEnabled && sentry.dsn
	script(src="https://browser.sentry-cdn.com/10.49.0/bundle.tracing.min.js" crossorigin="anonymous")
	script.
		Sentry.init({
			dsn: '#{sentry.dsn}',
			tunnel: '/sentun',
			integrations: [Sentry.browserTracingIntegration()],
			tracesSampleRate: 1.0,
			sendDefaultPii: true
		});
