.chat-sidebar
  .d-flex.justify-content-between.align-items-center.mb-3
    h6.mb-0
      i.bi.bi-chat-dots.me-1
      | AI Chat
    button.btn.btn-sm.btn-outline-secondary#clear-chat(title="Clear chat")
      i.bi.bi-trash

  #chat-messages.overflow-auto(style="height: calc(100vh - 220px)")

  .mt-2
    .input-group
      input.form-control#chat-input(type="text" placeholder="Ask about your knowledge...")
      button.btn.btn-primary#chat-send
        i.bi.bi-send
