extends layout

block content
	.d-flex.justify-content-between.align-items-center.mb-3
		h4
			i.bi.bi-journal-text
			span.ms-2 Notes
		button.btn.btn-primary#new-note-btn
			i.bi.bi-plus-lg
			span.ms-1 New Note

	.d-flex.align-items-center.mb-2.gap-2#batch-toolbar(data-type="notes")
		.form-check
			input.form-check-input#select-all-cb(type="checkbox")
			label.form-check-label.small(for="select-all-cb") Select all
		.batch-actions.d-none.d-flex.align-items-center.gap-2#batch-actions
			span.badge.bg-secondary#batch-count 0 selected
			button.btn.btn-outline-danger.btn-sm#batch-delete-btn
				i.bi.bi-trash.me-1
				| Delete
			button.btn.btn-outline-primary.btn-sm#batch-move-btn
				i.bi.bi-arrow-right-circle.me-1
				| Move
			button.btn.btn-outline-secondary.btn-sm#batch-copy-btn
				i.bi.bi-copy.me-1
				| Copy

	.position-relative#notes-drop-zone
		#notes-list.list-group
		#drop-overlay.drop-overlay.d-none
			.drop-overlay-card
				.drop-overlay-icon
					i.bi.bi-cloud-arrow-up
				h5 Files upload
				p.text-muted Drop files here to upload
		input#import-filepond(type="file" multiple hidden)

	#note-editor.d-none
		.mb-3
			.form-text Title
			input.form-control#note-title(type="text")
		.mb-3
			.form-text Tags
			input.form-control#note-tags(type="text")
		ul.nav.nav-tabs.mb-0#note-tabs
			li.nav-item
				button.nav-link.active#note-tab-preview(type="button") Preview
			li.nav-item
				button.nav-link#note-tab-edit(type="button") Edit
		#note-preview-container.preview-container.border.border-top-0.rounded-bottom.p-3(style="min-height: 400px")
		#editor-container.border-0.rounded.p-0.d-none(style="min-height: 400px")
		.d-flex.align-items-center.mt-3
			button.btn.btn-outline-secondary.me-2#back-to-list-btn Cancel
			button.btn.btn-outline-danger.ms-2#delete-note-btn.d-none
				i.bi.bi-trash.me-1
				span.ms-1 Delete
			.ms-auto
				button.btn.btn-primary#save-note-btn
					i.bi.bi-check-lg
					span.ms-1 Save

block scripts
	script(src="/static/js/editor.js" type="module")
	script(src="/static/js/notes.js")
	script(src="/static/js/batch.js")
