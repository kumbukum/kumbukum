{
  "name": "kumbukum",
  "version": "0.1.0",
  "private": true,
  "description": "Everything your AI needs to remember — Notes, Memory, URLs, AI Chat",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "nodemon --max-old-space-size=4096 --trace-warnings app.js",
    "start": "node app.js",
    "build": "node build.js"
  },
  "nodemonConfig": {
    "watch": [
      "app.js",
      "config.js",
      "db.js",
      "ws-server.js",
      "routes/",
      "middleware/",
      "model/",
      "modules/",
      "services/",
      "views/",
      "src/",
      "public/css/app.css",
      "public/js/auth.js"
    ],
    "ext": "js,pug,css",
    "ignore": [
      "public/js/vendor.js",
      "public/js/editor.js",
      "public/css/vendor.css"
    ],
    "exec": "node build.js && node app.js"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "@socket.io/redis-streams-adapter": "^0.3.1",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-blockquote": "^3.22.3",
    "@tiptap/extension-bullet-list": "^3.22.3",
    "@tiptap/extension-code-block": "^3.22.3",
    "@tiptap/extension-heading": "^3.22.3",
    "@tiptap/extension-horizontal-rule": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-ordered-list": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cheerio": "^1.2.0",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "crawlee": "^3.16.0",
    "croner": "^10.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "filepond": "^4.32.12",
    "formidable": "^3.5.4",
    "huebee": "^2.1.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "jsurl": "^0.1.5",
    "mammoth": "^1.12.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "n-readlines": "^3.4.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "pdfjs-parse": "^1.1.1",
    "pug": "^3.0.4",
    "socket.io": "^4.8.3",
    "striptags": "^3.2.0",
    "swagger-ui-express": "^5.0.1",
    "sweetalert2": "^11.26.24",
    "typesense": "^3.0.5"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "bufferutil",
        "utf-8-validate"
      ]
    },
    "overrides": {
      "bufferutil": "^4.1.0",
      "utf-8-validate": "^5.0.10",
      "@tiptap/core": "^3.22.3",
      "@tiptap/pm": "^3.22.3",
      "@tiptap/extension-code-block": "^3.22.3"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
