{
  "name": "kumbukum",
  "version": "0.1.0",
  "private": true,
  "description": "Everything your AI needs to remember — Notes, Memory, URLs, AI Chat",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --optimize_for_size --max-old-space-size=4096 --require ./tracing.cjs --import ./instrument.js app.js",
    "build": "node build.js",
    "dev": "nodemon --max-old-space-size=4096 --trace-warnings --require ./tracing.cjs --import ./instrument.js app.js",
    "test": "node --test --test-force-exit test/**/*.test.js",
    "test:mcp": "node --test --test-force-exit test/mcp/**/*.test.js",
    "docs:dev": "pnpm --filter @kumbukum/docs dev",
    "docs:build": "pnpm --filter @kumbukum/docs build",
    "docs:preview": "pnpm --filter @kumbukum/docs preview"
  },
  "nodemonConfig": {
    "watch": [
      "app.js",
      "config.js",
      "db.js",
      "routes/",
      "middleware/",
      "model/",
      "modules/",
      "services/",
      "views/",
      "src/",
      "public/css/app.css",
      "public/js/auth.js"
    ],
    "ext": "js,pug,css",
    "ignore": [
      "public/js/vendor.js",
      "public/js/editor.js",
      "public/css/vendor.css"
    ],
    "exec": "node build.js && node --require ./tracing.cjs app.js"
  },
  "dependencies": {
    "@keyv/valkey": "^1.0.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/instrumentation-ioredis": "^0.62.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "@simplewebauthn/server": "^13.3.0",
    "@socket.io/redis-streams-adapter": "^0.3.1",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-blockquote": "^3.22.3",
    "@tiptap/extension-bullet-list": "^3.22.3",
    "@tiptap/extension-code-block": "^3.22.3",
    "@tiptap/extension-heading": "^3.22.3",
    "@tiptap/extension-horizontal-rule": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-ordered-list": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cheerio": "^1.2.0",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "crawlee": "^3.16.0",
    "croner": "^10.0.1",
    "cytoscape": "^3.33.2",
    "cytoscape-fcose": "^2.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "file-type": "^22.0.1",
    "filepond": "^4.32.12",
    "formidable": "^3.5.4",
    "gray-matter": "^4.0.3",
    "huebee": "^2.1.1",
    "ioredis": "^5.10.1",
    "iovalkey": "^0.3.3",
    "jsonwebtoken": "^9.0.3",
    "jsurl2": "^2.2.0",
    "keyv": "^5.6.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.1",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "n-readlines": "^3.4.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "pdfjs-parse": "^1.1.1",
    "pug": "^3.0.4",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.34.5",
    "simple-git": "^3.36.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.2",
    "striptags": "^3.2.0",
    "swagger-ui-express": "^5.0.1",
    "sweetalert2": "^11.26.24",
    "turndown": "^7.2.4",
    "typesense": "^3.0.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scarf/scarf": "^1.4.0",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "vue-demi": "^0.14.10"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "bufferutil",
        "utf-8-validate"
      ]
    },
    "overrides": {
      "bufferutil": "^4.1.0",
      "utf-8-validate": "^5.0.10",
      "@tiptap/core": "^3.22.3",
      "@tiptap/pm": "^3.22.3",
      "@tiptap/extension-code-block": "^3.22.3"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
